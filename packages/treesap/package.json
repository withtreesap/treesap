{
  "name": "treesap",
  "version": "0.2.2",
  "description": "Opinionated Vite-first Node SSR framework.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run -c vitest.config.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "vite",
    "ssr",
    "node",
    "framework",
    "hono"
  ],
  "license": "MIT",
  "dependencies": {
    "hono": "^4.10.3"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withtreesap/treesap.git"
  },
  "bugs": {
    "url": "https://github.com/withtreesap/treesap/issues"
  },
  "homepage": "https://github.com/withtreesap/treesap#readme"
}
